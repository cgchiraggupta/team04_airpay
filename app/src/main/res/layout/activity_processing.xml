<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_flow_shell"
    android:gravity="center_horizontal"
    android:padding="@dimen/spacing_lg">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_flow_chip"
        android:paddingStart="14dp"
        android:paddingTop="8dp"
        android:paddingEnd="14dp"
        android:paddingBottom="8dp"
        android:text="@string/processing_guided_handoff"
        android:textColor="@color/accent"
        android:textSize="12sp" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/spacing_sm"
        android:background="@drawable/bg_flow_success_badge"
        android:paddingStart="14dp"
        android:paddingTop="8dp"
        android:paddingEnd="14dp"
        android:paddingBottom="8dp"
        android:text="@string/processing_meet_badge"
        android:textColor="@color/success"
        android:textSize="12sp"
        android:textStyle="bold" />

    <!-- Pulse animation container -->
    <FrameLayout
        android:layout_width="64dp"
        android:layout_height="64dp"
        android:layout_marginTop="@dimen/spacing_xl"
        android:layout_gravity="center_horizontal">

        <View
            android:id="@+id/pulseRing"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_gravity="center"
            android:background="@drawable/circle_pulse_ring" />

        <View
            android:id="@+id/pulseDot"
            android:layout_width="14dp"
            android:layout_height="14dp"
            android:layout_gravity="center"
            android:background="@drawable/circle_pulse_dot" />
    </FrameLayout>

    <TextView
        android:id="@+id/tvStatus"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/spacing_lg"
        android:text="@string/processing_connecting"
        android:textColor="@color/flow_text_on_gradient"
        android:textSize="28sp"
        android:fontFamily="sans-serif-medium"
        android:gravity="center" />

    <TextView
        android:id="@+id/tvPaymentDetails"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/spacing_sm"
        android:gravity="center"
        android:text="@string/processing_preparing_payment"
        android:textColor="@color/flow_text_muted"
        android:textSize="16sp" />

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/cardInfo"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/spacing_xl"
        app:cardBackgroundColor="@color/flow_surface_soft"
        app:cardCornerRadius="32dp"
        app:cardElevation="0dp"
        app:strokeColor="@color/flow_receipt_line"
        app:strokeWidth="1dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="@dimen/spacing_lg">

            <com.google.android.material.progressindicator.LinearProgressIndicator
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:indeterminate="true"
                app:indicatorColor="@color/flow_lime"
                app:trackColor="@color/flow_surface_chip"
                app:trackCornerRadius="4dp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_lg"
                android:text="@string/processing_what_happens_next"
                android:textColor="@color/flow_text_dark"
                android:textSize="18sp"
                android:fontFamily="sans-serif-medium" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_md"
                android:background="@drawable/bg_flow_chip"
                android:padding="@dimen/spacing_md"
                android:text="@string/processing_steps"
                android:textColor="@color/flow_text_muted"
                android:textSize="14sp"
                android:lineSpacingMultiplier="1.3" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_md"
                android:text="@string/processing_keep_open"
                android:textColor="@color/text_hint"
                android:textSize="13sp"
                android:lineSpacingMultiplier="1.3" />
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <LinearLayout
        android:id="@+id/layoutPinEntry"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/spacing_lg"
        android:orientation="vertical"
        android:visibility="gone">

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardBackgroundColor="@color/flow_surface_soft"
            app:cardCornerRadius="32dp"
            app:cardElevation="0dp"
            app:strokeColor="@color/flow_receipt_line"
            app:strokeWidth="1dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="@dimen/spacing_lg">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_flow_success_badge"
                    android:paddingStart="14dp"
                    android:paddingTop="8dp"
                    android:paddingEnd="14dp"
                    android:paddingBottom="8dp"
                    android:text="@string/processing_secure_step"
                    android:textColor="@color/success"
                    android:textSize="12sp" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/spacing_md"
                    android:text="@string/processing_enter_pin_popup"
                    android:textColor="@color/flow_text_dark"
                    android:textSize="22sp"
                    android:fontFamily="sans-serif-medium"
                    android:lineSpacingMultiplier="1.1" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/spacing_sm"
                    android:text="@string/processing_pin_explainer"
                    android:textColor="@color/flow_text_muted"
                    android:textSize="14sp"
                    android:lineSpacingMultiplier="1.3" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnManualReceipt"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:layout_marginTop="@dimen/spacing_lg"
                    android:background="@drawable/bg_flow_lime_button"
                    android:text="@string/processing_entered_pin"
                    android:textAllCaps="false"
                    android:textColor="@color/flow_lime_dark"
                    android:textSize="17sp"
                    android:fontFamily="sans-serif-medium"
                    app:backgroundTint="@android:color/transparent"
                    app:cornerRadius="22dp" />
            </LinearLayout>

        </com.google.android.material.card.MaterialCardView>

    </LinearLayout>

</LinearLayout>
