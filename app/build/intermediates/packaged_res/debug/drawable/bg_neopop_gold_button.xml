<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- NeoPOP hard shadow -->
    <item
        android:top="5dp"
        android:left="0dp"
        android:right="0dp"
        android:bottom="0dp">
        <shape android:shape="rectangle">
            <solid android:color="@color/neopop_shadow" />
            <corners android:radius="18dp" />
        </shape>
    </item>
    <!-- Main gold button -->
    <item
        android:top="0dp"
        android:left="0dp"
        android:right="0dp"
        android:bottom="5dp">
        <shape android:shape="rectangle">
            <solid android:color="@color/quantum_gold" />
            <corners android:radius="18dp" />
        </shape>
    </item>
</layer-list>
